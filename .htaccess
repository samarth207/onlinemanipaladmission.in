Options -Indexes
DirectoryIndex index.html index.php

RewriteEngine On
RewriteBase /

# ── www → non-www (canonical domain) ────────────────────────────────────
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ── Security: block direct access to sensitive PHP config files ───────────
<FilesMatch "^(cms-config|cms-db|cms-auth|cms-utils|db-config|setup-database)\.php$">
    Order deny,allow
    Deny from all
</FilesMatch>
<FilesMatch "^setup-database\.sql$">
    Order deny,allow
    Deny from all
</FilesMatch>

# ── Canonical: /index.html → / (root homepage) ─────────────────────────
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^ / [R=301,L]

# ── Canonical: /dir/index.html → /dir/ ───────────────────────────────────
RewriteCond %{THE_REQUEST} \s/+(.*/)index\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ── Canonical: /page.html → /page ────────────────────────────────────────
RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ── Redirect legacy /wp-content/themes/ to local static mirror ───────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^wp-content/themes/(.*)$ /assets/static/wp-content/themes/$1 [L,NC]

# ── Redirect legacy /wp-content/uploads/ to static mirror ────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^wp-content/uploads/(.*)$ /assets/static/wp-content/uploads/$1 [L,NC]

# ── Redirect /assets/images/ shorthand to flamingo theme images ──────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^assets/images/(.*)$ /assets/static/wp-content/themes/flamingo/assets/images/$1 [L,NC]

# ── wp-json API routing ───────────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^wp-json/api/v1/([a-z0-9_-]+)/?$ wp-json/api/v1/$1/index.php [L]

# ── Serve .html files at clean URLs (no extension) ────────────────────────
# (blog and admin routing handled by their own .htaccess files)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# ── Serve .php files at clean URLs (no extension) ────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# ── Charset ───────────────────────────────────────────────────────────────
AddDefaultCharset UTF-8
