al.com\/blogs\/author\/ajmal-varikkodan"}]}},"acf":[],"_links":{"self":[{"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/posts\/22528006","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/users\/4"}],"replies":[{"embeddable":true,"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/comments?post=22528006"}],"version-history":[{"count":1,"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/posts\/22528006\/revisions"}],"predecessor-version":[{"id":27500038,"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/posts\/22528006\/revisions\/27500038"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/media\/6717746"}],"wp:attachment":[{"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/media?parent=22528006"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/categories?post=22528006"},{"taxonomy":"post_tag","embeddable":true,"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/tags?post=22528006"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}