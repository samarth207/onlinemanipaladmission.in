cessor-version":[{"id":27501507,"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/posts\/685643\/revisions\/27501507"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/media\/676437"}],"wp:attachment":[{"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/media?parent=685643"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/categories?post=685643"},{"taxonomy":"post_tag","embeddable":true,"href":"https:\/\/www.onlinemanipal.com\/wp-json\/wp\/v2\/tags?post=685643"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}