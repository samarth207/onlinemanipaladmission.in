209-96x96.jpg","caption":"Krishnanjali KU"},"description":"Every great piece of content starts with a story, and Krishnanjali knows how to tell it right. With over four years of experience, she has been transforming ideas into compelling narratives that captivate audiences and drive business growth. Over the span of her experience, she has shown her expertise in writing through blogs, PRs, datasheets, white papers, social media marketing, case studies, technical articles, and so on.","sameAs":["https:\/\/www.linkedin.com\/in\/krishnanjali-ku-9b2141185"],"url":"https:\/\/www.onlinemanipaladmission.in\/blogs\/author\/krishnanjali"}]}},"acf":[],"_links":{"self":[{"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/posts\/29476737","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/users\/126"}],"replies":[{"embeddable":true,"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/comments?post=29476737"}],"version-history":[{"count":1,"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/posts\/29476737\/revisions"}],"predecessor-version":[{"id":29476946,"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/posts\/29476737\/revisions\/29476946"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/media\/29476856"}],"wp:attachment":[{"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/media?parent=29476737"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/categories?post=29476737"},{"taxonomy":"post_tag","embeddable":true,"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/tags?post=29476737"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}