tps:\\\/\\\/www.onlinemanipaladmission.in\\\/\",\"logo\":{\"@type\":\"ImageObject\",\"inLanguage\":\"en-GB\",\"@id\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/#\\\/schema\\\/logo\\\/image\\\/\",\"url\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/wp-content\\\/uploads\\\/2022\\\/07\\\/MicrosoftTeams-image-9.png\",\"contentUrl\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/wp-content\\\/uploads\\\/2022\\\/07\\\/MicrosoftTeams-image-9.png\",\"width\":1000,\"height\":1000,\"caption\":\"Online Manipal\"},\"image\":{\"@id\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/#\\\/schema\\\/logo\\\/image\\\/\"},\"sameAs\":[\"https:\\\/\\\/www.facebook.com\\\/onlinemanipal\",\"https:\\\/\\\/www.instagram.com\\\/onlinemanipal\\\/\",\"https:\\\/\\\/www.youtube.com\\\/channel\\\/UC6EgEsVbor7Tpz3xARIhLzQ\"]},{\"@type\":\"Person\",\"@id\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/#\\\/schema\\\/person\\\/fa5d09dfd75772e7a56fc06fe5b11ac2\",\"name\":\"Priyankaa Srinivasan\",\"image\":{\"@type\":\"ImageObject\",\"inLanguage\":\"en-GB\",\"@id\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/wp-content\\\/uploads\\\/2025\\\/04\\\/priyanka-srinivasan-96x96.png\",\"url\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/wp-content\\\/uploads\\\/2025\\\/04\\\/priyanka-srinivasan-96x96.png\",\"contentUrl\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/wp-content\\\/uploads\\\/2025\\\/04\\\/priyanka-srinivasan-96x96.png\",\"caption\":\"Priyankaa Srinivasan\"},\"description\":\"Priyankaa is a content writer in the ever-evolving field of EdTech. She handles various aspects of content marketing including blogs, PR articles, video marketing among others. She moved to content marketing after a short career in journalism, working with reputed media houses. She completed her masters in Broadcast Journalism from Indian Institute of Journalism and New Media, Bengaluru and BA Journalism from Mount Carmel College, Bengaluru.\u202f\",\"url\":\"https:\\\/\\\/www.onlinemanipalad