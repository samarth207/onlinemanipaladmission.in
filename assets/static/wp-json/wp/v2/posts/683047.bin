\":1412,\"height\":791,\"caption\":\"Online BA\"},{\"@type\":\"BreadcrumbList\",\"@id\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/blogs\\\/why-pursue-online-degree-from-sikkim-manipal-university#breadcrumb\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"10 reasons to pursue an online degree from SMU\"}]},{\"@type\":\"WebSite\",\"@id\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/#website\",\"url\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/\",\"name\":\"Online Manipal\",\"description\":\"Online Manipal\",\"publisher\":{\"@id\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/#organization\"},\"potentialAction\":[{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/?s={search_term_string}\"},\"query-input\":{\"@type\":\"PropertyValueSpecification\",\"valueRequired\":true,\"valueName\":\"search_term_string\"}}],\"inLanguage\":\"en-GB\"},{\"@type\":\"Organization\",\"@id\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/#organization\",\"name\":\"Online Manipal\",\"url\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/\",\"logo\":{\"@type\":\"ImageObject\",\"inLanguage\":\"en-GB\",\"@id\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/#\\\/schema\\\/logo\\\/image\\\/\",\"url\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/wp-content\\\/uploads\\\/2022\\\/07\\\/MicrosoftTeams-image-9.png\",\"contentUrl\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/wp-content\\\/uploads\\\/2022\\\/07\\\/MicrosoftTeams-image-9.png\",\"width\":1000,\"height\":1000,\"caption\":\"Online Manipal\"},\"image\":{\"@id\":\"https:\\\/\\\/www.onlinemanipaladmission.in\\\/#\\\/schema\\\/logo\\\/image\\\/\"},\"sameAs\":[\"https:\\\/\\\/www.facebook.com\\\/onlinemanipal\",\"https:\\\/\\\/www.instagram.com\\\/onlinemanipal\\\/\",\"https:\\\/\\\/www.youtube.