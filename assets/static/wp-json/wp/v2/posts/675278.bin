le":true,"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/media\/674101"}],"wp:attachment":[{"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/media?parent=675278"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/categories?post=675278"},{"taxonomy":"post_tag","embeddable":true,"href":"https:\/\/www.onlinemanipaladmission.in\/wp-json\/wp\/v2\/tags?post=675278"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}